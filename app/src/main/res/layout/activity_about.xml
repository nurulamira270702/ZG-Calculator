<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="@color/cream">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="About Developer"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/dark_gold"
            android:layout_gravity="center"
            android:layout_marginBottom="20dp"/>

        <!-- Developer Details -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Developer Details"
            android:textStyle="bold"
            android:textSize="22sp"
            android:textColor="@color/dark_gold"
            android:layout_marginBottom="10dp"/>

        <TableLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/gold"
            android:padding="12dp"
            android:stretchColumns="1">

            <TableRow>
                <TextView
                    android:text="Name"
                    android:textStyle="bold"
                    android:padding="8dp"/>

                <TextView
                    android:text="NURUL AMIRA BINTI ABD RANI"
                    android:padding="8dp"/>
            </TableRow>

            <TableRow>
                <TextView
                    android:text="Student ID"
                    android:textStyle="bold"
                    android:padding="8dp"/>

                <TextView
                    android:text="2024776263"
                    android:padding="8dp"/>
            </TableRow>

            <TableRow>
                <TextView
                    android:text="Programme Code"
                    android:textStyle="bold"
                    android:padding="8dp"/>

                <TextView
                    android:text="CS240"
                    android:padding="8dp"/>
            </TableRow>

            <TableRow>
                <TextView
                    android:text="Group"
                    android:textStyle="bold"
                    android:padding="8dp"/>

                <TextView
                    android:text="CDCS2405B"
                    android:padding="8dp"/>
            </TableRow>

        </TableLayout>

        <!-- Application Information -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Application Information"
            android:textStyle="bold"
            android:textSize="22sp"
            android:textColor="@color/dark_gold"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="10dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/gold"
            android:padding="12dp"
            android:text="Application Name: Zakat Gold Calculator&#10;&#10;Version: 1.0&#10;&#10;Description: This application helps users estimate zakat payment for gold keeping and gold wearing based on current gold value and zakat calculation rules."
            android:textSize="16sp"/>

        <!-- Application Website -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Application Website"
            android:textStyle="bold"
            android:textSize="22sp"
            android:textColor="@color/dark_gold"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="10dp"/>

        <TextView
            android:id="@+id/tvGithub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="https://github.com/yourusername/ZakatGoldCalculator"
            android:textColor="#0000EE"
            android:textSize="18sp"
            android:autoLink="web"/>

        <!-- Copyright -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Copyright"
            android:textStyle="bold"
            android:textSize="22sp"
            android:textColor="@color/dark_gold"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="10dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/gold"
            android:padding="12dp"
            android:text="Copyright © 2026 Nurul Amira Binti Abd Rani. All Rights Reserved. This application was developed for educational purposes as part of the ICT602 Mobile Technology course."
            android:textSize="16sp"/>

    </LinearLayout>

</ScrollView>
